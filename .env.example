# Copy this file to .env and fill in your keys
PORT=3000

# Groq API (transcription)
GROQ_API_KEY=gsk_...

# Discord Bot (Record tab — desktop only)
DISCORD_BOT_TOKEN=MTA...

# Discord OAuth (login — get from discord.com/developers)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://scryb.onrender.com/auth/discord/callback

# Neon PostgreSQL (get connection string from neon.tech)
DATABASE_URL=postgresql://neondb_owner:...@ep-....neon.tech/neondb?sslmode=require

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# AES-256-GCM encryption key for transcriptions — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
